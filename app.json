{
  "expo": {
    "name": "ChessTimeIOS",
    "slug": "aidso-ctrackr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.sameer.chesstimeios",
      "supportsTablet": true,
      "bitcode": false,
      "infoPlist": {
        "NSCameraUsageDescription": "ChessTime uses your camera for video chat during games.",
        "NSMicrophoneUsageDescription": "ChessTime uses your microphone for voice chat during games.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.sameer.chesstimeios",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "backgroundColor": "#1c1c1e",
          "resizeMode": "contain"
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Allow ChessTime to access your camera",
          "microphonePermission": "Allow ChessTime to access your microphone"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "packagingOptions": {
              "pickFirsts": [
                "**/libc++_shared.so",
                "**/libjingle_peerconnection_so.so"
              ]
            }
          }
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "a4ec8cfb-5320-4d37-a778-382214d385d9"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a4ec8cfb-5320-4d37-a778-382214d385d9"
    },
    "owner": "gramaone2021s-team"
  }
}
